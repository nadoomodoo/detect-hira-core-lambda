{
  "name": "detect-hira-code",
  "version": "0.1.0",
  "description": "HIRA 약가코드(9자리)를 이미지에서 검출하고 제약사명을 옆에 표시하는 도구",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx --env-file=.env src/index.ts",
    "dev": "tsx --env-file=.env src/index.ts",
    "batch": "tsx --env-file=.env src/batch.ts",
    "serve": "node dist/server.js",
    "serve:dev": "tsx --env-file=.env src/server.ts",
    "gateway:dev": "tsx --env-file=.env src/gateway.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@aws-sdk/s3-request-presigner": "^3.1084.0",
    "@google-cloud/storage": "^7.14.0",
    "@google-cloud/vertexai": "^1.12.0",
    "@prisma/client": "^6.19.3",
    "csv-parse": "^7.0.1",
    "google-auth-library": "^9.1.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^22.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0"
  }
}

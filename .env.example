# ==========================================
# Vertex AI / Gemini 설정
# ==========================================
# 실제 값은 .env (git ignored) 에 넣고, 이 파일은 자리표시자(placeholder)만 둡니다.
# vertex.txt 에 접속정보가 있으나 해당 파일은 커밋 금지(.gitignore 참조).

MODEL_PROVIDER=vertex

# 사용할 Gemini 모델
# - gemini-2.5-flash-lite : 2026-07-22 폐기 예정 (vertex.txt 기준값)
# - gemini-3.1-flash-lite  : 2026-05 GA 신버전 (권장)
# 정확도가 부족하면 gemini-3-pro / gemini-3-flash 로 변경.
MODEL_NAME=gemini-3.1-flash-lite

# OCR 반복 루프(같은 코드를 엉뚱한 좌표로 대량 반복 생성)가 재시도로도
# 해소 안 될 때만 1회 에스컬레이션할 상위 모델.
OCR_FALLBACK_MODEL=gemini-3.5-flash

# Vertex API 키
VERTEX_API_KEY=your-vertex-api-key

# Vertex AI 프로젝트/위치
# 주의: Gemini 3.x 계열은 `global` 리전에서만 제공 (us-central1 등에서는 404).
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=global

# 서비스 계정 JSON (한 줄로 이스케이프하여 입력).
# vertex.txt 의 GOOGLE_APPLICATION_CREDENTIALS_JSON 값을 그대로 복사.
# 또는 서비스 계정 키 파일 경로를 GOOGLE_APPLICATION_CREDENTIALS 로 지정해도 됨.
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","...":"..."}

# ==========================================
# HIRA 약가코드 마스터 데이터
# ==========================================
# 9자리 drug_code → 제약사명/의약품명 CSV 경로
DRUG_MASTER_PATH=/Users/hamelmoon/workspaces/ecso-projects/data/master/drug_master_merged.csv

# 제약사(업체) 마스터 CSV — 업체명,사업자번호,주소,대표자
# lambda-extract 응답의 businessNumber(사업자번호) 조인에 사용.
MANUFACTURER_MASTER_PATH=/Users/hamelmoon/workspaces/ecso-projects/data/master/manufacturer_master_20260620.csv

# ==========================================
# 이미지 전처리 (토큰/비용 절약 + 검출률)
# ==========================================
# Gemini 는 768px 타일 단위로 토큰을 계산: tiles = ceil(w/768) × ceil(h/768), 타일당 258 토큰.
#
# 리사이즈는 '짧은 변 보장' 방식:
#  - 짧은 변이 PREPROCESS_MIN_SHORT_EDGE 미만이면 스케일 업 (작은 글씨 OCR 누락 방지)
#  - 긴 변이 PREPROCESS_MAX_LONG_EDGE_CAP 초과면 축소 (토큰 과다 방지)
#  - 단, 축소로 짧은 변이 MIN_SHORT_EDGE 아래로 내려가면 MIN_SHORT_EDGE 를 우선
#
# 세로로 긴 이미지(여러 처방전 이어붙음 등)에서 긴 변을 강제 축소하면
# 폭이 좁아져 약가코드 숫자가 작아지고 OCR이 누락되는 문제를 해결한다.
PREPROCESS_MIN_SHORT_EDGE=1000
PREPROCESS_MAX_LONG_EDGE_CAP=4096

# JPEG 재인코딩 화질 (1~100). 권장 85 이상 (너무 낮으면 OCR 정확도 하락).
PREPROCESS_JPEG_QUALITY=88

# ==========================================
# 한글 폰트 (이미지 위 제약사명 렌더링용)
# ==========================================
# 비워두면 시스템 기본 폰트 사용. 배포 시 OFL 폰트(Noto Sans KR 등) 경로 지정 권장.
FONT_PATH=

# ==========================================
# AWS S3 (Lambda 배포 시 — 로컬 CLI에서는 불필요)
# ==========================================
# 이미지 입력/출력을 S3로 중계. API Gateway 10MB 페이로드 제한 우회.
# - 입력: { inputBucket, inputKey } 로 S3 객체 참조 (inputBucket 생략 시 아래 값 사용)
# - 출력: 결과 이미지를 S3에 PUT 후 presigned URL 반환
# 둘 다 비워두면 base64 직접 입출력으로 동작(소형 이미지용).
S3_INPUT_BUCKET=
S3_OUTPUT_BUCKET=

# presigned URL 만료 시간 (초). 기본 3600 (1시간).
S3_PRESIGN_TTL=3600


# ── 약가 API fallback (data.go.kr 15054445 약가기준정보조회서비스) ──
# 미조회 약가코드만 실시간 조회 → DrugMaster write-through. 미설정 시 fallback 무동작.
# 엔드포인트/필드명은 스펙 확정 후 아래로 오버라이드(기본값은 잠정).
HIRA_API_KEY=
# HIRA_API_ENDPOINT=https://apis.data.go.kr/B551182/dgamtCrtrInfoService/getDgamtList
# HIRA_FIELD_CODE=mdsCd
# HIRA_FIELD_MFR=entpName
# HIRA_FIELD_NAME=mdsCdNm

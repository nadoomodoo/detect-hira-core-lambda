{
  "name": "@platform/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "serve": "node dist/server.js",
    "serve:dev": "tsx --env-file=../../.env src/server.ts",
    "gateway": "node dist/gateway.js",
    "gateway:dev": "tsx --env-file=../../.env src/gateway.ts",
    "batch": "tsx --env-file=../../.env src/batch.ts",
    "bench": "tsx --env-file=../../.env src/bench.ts",
    "seed:extract": "tsx --env-file=../../.env scripts/seed-extract.mts",
    "seed:drug-prices": "tsx --env-file=../../.env scripts/seed-drug-prices.mts",
    "test:extract": "tsx scripts/test-extract-logic.mts",
    "typecheck": "tsc --noEmit",
    "regression": "tsx scripts/regression.mts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@aws-sdk/s3-request-presigner": "^3.1084.0",
    "@google-cloud/bigquery": "^7.9.4",
    "@google-cloud/storage": "^7.14.0",
    "@google/genai": "^2.12.0",
    "@platform/db": "workspace:*",
    "csv-parse": "^7.0.1",
    "exceljs": "^4.4.0",
    "google-auth-library": "^9.1.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^22.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0"
  }
}

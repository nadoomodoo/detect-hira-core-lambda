{
  "name": "cso-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": { "node": ">=20" },
  "scripts": {
    "build:db": "pnpm --filter @platform/db build",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm --filter @platform/db build && pnpm -r --filter '!@platform/db' build"
  }
}

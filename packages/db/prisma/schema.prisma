// API 판매 플랫폼 — 과금 원장 + 마스터 (Cloud SQL Postgres)
// 상세: docs/IMPLEMENTATION-PLAN.md §4

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum BillingUnit {
  CALL
  IMAGE
  PAGE
}

enum ProductStatus {
  ACTIVE
  BETA
  DEPRECATED
}

enum TxType {
  TOPUP
  CHARGE
  REFUND
}

enum ReqStatus {
  NEW
  CONTACTED
  APPROVED
  REJECTED
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String?
  passwordHash String? // 고객 이메일/암호 로그인 (어드민 Google 계정은 null)
  role         Role            @default(USER)
  emailVerified DateTime? // 이메일 인증 완료 시각. null = 미인증(로그인 차단). 어드민(Google)은 가입 시 즉시 인증됨
  createdAt    DateTime        @default(now())
  apiKeys      ApiKey[]
  credit       CreditAccount?
  entitlements Entitlement[]
  creditTxs    CreditTx[]
  accessReqs   AccessRequest[]
  emailTokens  EmailVerificationToken[]
  topUps       TopUpRequest[]

  @@index([role])
}

// 무통장 입금 충전 요청 — 고객이 금액 입력 + 환불약관 동의 후 생성.
// 입금 확인되면 어드민이 확정 → chargeKrw(부가세 제외 순액)를 잔액에 충전.
model TopUpRequest {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  depositKrw    Int // 고객이 입금할 금액(부가세 포함)
  chargeKrw     Int // 충전될 잔액(부가세 제외 순액) = deposit - vat
  vatKrw        Int // 부가세(10%)
  status        String    @default("pending") // pending | confirmed | canceled
  termsAgreedAt DateTime // 환불약관 동의 시각
  createdAt     DateTime  @default(now())
  confirmedAt   DateTime?
  confirmedBy   String? // 확정 처리 어드민 id

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model EmailVerificationToken {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  keyHash    String    @unique // SHA-256(secret) — 원문 미저장
  prefix     String // 표시용 앞 8자
  active     Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([active])
}

model Product {
  id           String                @id @default(cuid())
  slug         String                @unique // hira-detect
  name         String
  category     String? // 분야 카테고리 (예: 제약 CSO)
  description  String? // 랜딩 카탈로그에 표시되는 API 설명
  priceKrw     Int
  billingUnit  BillingUnit           @default(CALL)
  freeQuota    Int                   @default(10)
  processorUrl String
  status       ProductStatus         @default(ACTIVE)
  updatedAt    DateTime              @updatedAt
  entitlements Entitlement[]
  priceHistory ProductPriceHistory[]
}

model ProductPriceHistory {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  priceKrw      Int
  effectiveFrom DateTime @default(now())

  @@index([productId, effectiveFrom])
}

model Entitlement {
  id        String  @id @default(cuid())
  userId    String
  productId String
  enabled   Boolean @default(true)
  freeUsed  Int     @default(0)
  user      User    @relation(fields: [userId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model CreditAccount {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id])
  balanceKrw Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model CreditTx {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  deltaKrw     Int
  type         TxType
  productId    String?
  unitPriceKrw Int?
  requestId    String?  @unique // idempotency
  memo         String?
  adminId      String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model AccessRequest {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  productId      String
  contact        String
  expectedVolume String?
  purpose        String?
  status         ReqStatus @default(NEW)
  createdAt      DateTime  @default(now())

  @@index([status, createdAt])
}

model CoMarketingMapping {
  id           String   @id @default(cuid())
  drugCode     String   @unique // 9자리
  originalName String?
  displayName  String
  active       Boolean  @default(true)
  memo         String?
  updatedBy    String?
  updatedAt    DateTime @updatedAt

  @@index([active])
}

model DemoUsage {
  id    String @id @default(cuid())
  ip    String
  day   String // YYYY-MM-DD (UTC)
  count Int    @default(0)

  @@unique([ip, day])
}

model DrugMaster {
  drugCode         String   @id // 9자리
  manufacturerName String
  drugName         String?
  source           String   @default("seed") // seed | hira-api | admin
  updatedAt        DateTime @updatedAt

  @@index([manufacturerName])
}

// 벌크 처리 작업 (동기 폴백 또는 Cloud Tasks 비동기 공용)
model Job {
  id        String    @id @default(cuid())
  userId    String
  productId String
  total     Int
  done      Int       @default(0)
  status    String    @default("processing") // processing | done
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  items     JobItem[]

  @@index([userId, createdAt])
}

model JobItem {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  idx       Int // 요청 내 순서
  status    String   @default("pending") // pending | ok | failed
  requestId String   @unique // 과금 idempotency
  input     Json // { kind: "image"|"imageUrl", v: string } — 워커 처리 입력
  costKrw   Int      @default(0)
  result    Json? // 성공 시 검출 요약(items/uniqueManufacturers 등)
  error     String?
  createdAt DateTime @default(now())

  @@index([jobId])
}
